# Backend environment variables example
# Copy this to .env and fill with real values for production/dev

# Server
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# Firebase service account JSON (stringified). If not set, a local in-memory mock is used for dev.
# Example:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# Timezone and session defaults
DEFAULT_TIMEZONE=UTC
SESSION_DURATION_MINUTES=60

# SMTP for email notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=unibridge@example.com
PORT=3001
FIREBASE_PROJECT_ID=unibridge-7ea3e
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"unibridge-7ea3e"}
# Optional if you prefer a local file instead of inline JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json
GEMINI_API_KEY=your_gemini_api_key_here
ALLOWED_ORIGIN=http://localhost:5173